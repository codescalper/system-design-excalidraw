      "link": null,
      "locked": false,
      "text": "Step 5 — Deep dives.",
      "fontSize": 25.70141018641881,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 5 — Deep dives.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cc-27PmqJ-VoKGBZl2b9i",
      "type": "text",
      "x": 493.762724177383,
      "y": -2669.902164268628,
      "width": 702.5911882189494,
      "height": 326.38910186418826,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8r",
      "roundness": null,
      "seed": 1330830984,
      "version": 1053,
      "versionNonce": 2050080248,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773766283225,
      "link": null,
      "locked": false,
      "text": "The interviewer will push here: \"What if the\nDB goes down?\" / \"How do you handle hash\ncollisions?\" / \"What if one short code gets\n10M hits?\" Drive this yourself if they don't\n— proactively raise the hard problems and\nexplain your trade-offs. This is what\nseparates good candidates from great\nones.",
      "fontSize": 32.638910186418826,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The interviewer will push here: \"What if the DB goes down?\" / \"How do you handle hash collisions?\" / \"What if one short code gets 10M hits?\" Drive this yourself if they don't — proactively raise the hard problems and explain your trade-offs. This is what separates good candidates from great ones.",
      "autoResize": false,
      "lineHeight": 1.25
    },
