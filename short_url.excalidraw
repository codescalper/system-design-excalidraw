    {
      "id": "LzNmrppQUuraJoO4X4dM0",
      "type": "text",
      "x": 667.2803274914054,
      "y": -5758.309742999727,
      "width": 211.099853515625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
