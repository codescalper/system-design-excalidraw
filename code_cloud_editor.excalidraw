    },
    {
      "id": "7jLvYiFTOPr7Jz1wAfj9L",
      "type": "text",
      "x": -4791.655700314041,
      "y": -4335.321695030886,
      "width": 211.099853515625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
