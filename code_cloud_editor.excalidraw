    {
      "id": "T-PnbEwIy2Jo430tH_K0R",
      "type": "text",
      "x": -5023.920417958538,
      "y": -2769.175284388678,
      "width": 366.86737060546875,
      "height": 32.12676273302351,
      "angle": 0,
      "strokeColor": "#1e1e1e",
