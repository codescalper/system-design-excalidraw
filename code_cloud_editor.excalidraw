    {
      "id": "pdz_iYM9FTy_0CUpp0I6K",
      "type": "text",
      "x": -461.42184369297775,
      "y": 2083.074708326858,
      "width": 787.1394653320312,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
