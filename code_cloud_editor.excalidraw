    {
      "id": "IvaGNRG2zRWWTzeZIVYs4",
      "type": "text",
      "x": -520.5048566502232,
      "y": -791.0474566637149,
      "width": 332.0181579589844,
      "height": 32.12676273302351,
      "angle": 0,
      "strokeColor": "#1e1e1e",
