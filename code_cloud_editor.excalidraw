      "updated": 1775302023049,
      "link": null,
      "locked": false,
      "text": "Step 2 — Estimate scale. ",
      "fontSize": 25.70141018641881,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 2 — Estimate scale. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IXNoiPyXAotF8x4Pz5P5z",
      "type": "text",
      "x": -516.5760618979457,
      "y": -715.1375697331177,
      "width": 702.5911882189494,
      "height": 285.5904641311647,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0B",
      "roundness": null,
      "seed": 1845699724,
      "version": 785,
      "versionNonce": 1113507852,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775302023049,
      "link": null,
      "locked": false,
      "text": "This isn't about getting exact numbers —\nit's about identifying the nature of the\nproblem. A 100:1 read/write ratio tells you\nthe system is read-heavy, which means\ncaching is critical. 10:1 might mean DB\nreplicas suffice. Write your math visibly;\ninterviewers want to follow your reasoning.",
      "fontSize": 32.638910186418826,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This isn't about getting exact numbers — it's about identifying the nature of the problem. A 100:1 read/write ratio tells you the system is read-heavy, which means caching is critical. 10:1 might mean DB replicas suffice. Write your math visibly; interviewers want to follow your reasoning.",
      "autoResize": false,
      "lineHeight": 1.25
    },
