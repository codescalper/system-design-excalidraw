      "seed": 300651261,
      "version": 739,
      "versionNonce": 2095573747,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775131791226,
      "link": null,
      "locked": false,
      "text": "Identify clients? \n- Authenticated users: authorization header (User ID)\n- Public APIS : Ip address (USER-AGENT , X-Forwarded-for)\n- Developer APIs: API EYS (X-API-KEY)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Identify clients? \n- Authenticated users: authorization header (User ID)\n- Public APIS : Ip address (USER-AGENT , X-Forwarded-for)\n- Developer APIs: API EYS (X-API-KEY)",
      "autoResize": false,
      "lineHeight": 1.25
    },
