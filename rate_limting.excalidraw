    {
      "id": "ezMCRSh2eRE4AqV7-hrgA",
      "type": "text",
      "x": -3449.6655449502864,
      "y": -488.9874268658373,
      "width": 332.0181579589844,
      "height": 32.12676273302351,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
