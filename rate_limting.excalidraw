      "isDeleted": false,
      "boundElements": [],
      "updated": 1775131683066,
      "link": null,
      "locked": false,
      "text": "- Less context, only information of http request itself and\nwhere do we store rate liiting state ?? (redis internal\ndependency)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Less context, only information of http request itself and where do we store rate liiting state ?? (redis internal dependency)",
      "autoResize": false,
