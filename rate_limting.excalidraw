    },
    {
      "id": "cJkwEC17gz4eHgwFPkWe3",
      "type": "text",
      "x": 571.4540936113325,
      "y": 1875.5926474774212,
      "width": 749.8611393548221,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
