    {
      "id": "UXHWoxCCMDLV7x4f0yJq0",
      "type": "text",
      "x": -3454.4686476552583,
      "y": 229.16304981649546,
      "width": 366.86737060546875,
      "height": 32.12676273302351,
      "angle": 0,
      "strokeColor": "#1e1e1e",
