      "link": null,
      "locked": false,
      "text": "Step1: Clarify requirements. ",
      "fontSize": 25.70141018641881,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step1: Clarify requirements. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9ilCQdl3JgrBb2oEqi-DE",
      "type": "text",
      "x": -3222.2039300107617,
      "y": -1336.9833608257136,
      "width": 211.099853515625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a9",
      "roundness": null,
      "seed": 2002383923,
      "version": 103,
      "versionNonce": 2050250205,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775126960631,
      "link": null,
      "locked": false,
      "text": "System Design TIPS ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "System Design TIPS ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yQpzxLH9SKiL0VvglkUXL",
      "type": "text",
      "x": -3440.8517440525225,
      "y": -1112.909681689212,
      "width": 702.5911882189494,
      "height": 407.9863773302353,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aA",
      "roundness": null,
      "seed": 185791955,
      "version": 704,
      "versionNonce": 541561405,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775126960631,
      "link": null,
      "locked": false,
      "text": "Never start designing immediately. Spend\nthe first few minutes asking questions. The\ninterviewer often intentionally leaves things\nvague. You want to nail down: what the\nsystem does, who uses it, what scale you're\ndesigning for, and what's explicitly out of\nscope. For a URL shortener: \"Do we need\nanalytics? Custom aliases? Expiry? Mobile vs\nweb?\" This shows you think before you\nbuild.",
      "fontSize": 32.638910186418826,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Never start designing immediately. Spend the first few minutes asking questions. The interviewer often intentionally leaves things vague. You want to nail down: what the system does, who uses it, what scale you're designing for, and what's explicitly out of scope. For a URL shortener: \"Do we need analytics? Custom aliases? Expiry? Mobile vs web?\" This shows you think before you build.",
      "autoResize": false,
      "lineHeight": 1.25
    },
