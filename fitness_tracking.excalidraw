    {
      "id": "BnVrGNm4Oge-okclPRA_O",
      "type": "text",
      "x": -3123.579842942609,
      "y": -1460.8276060720764,
      "width": 366.86737060546875,
      "height": 32.12676273302351,
      "angle": 0,
      "strokeColor": "#1e1e1e",
