    },
    {
      "id": "45YADLJCa2cX74sO7vSdw",
      "type": "text",
      "x": -3059.6937272803916,
      "y": 695.1440822361637,
      "width": 787.1394653320312,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1g",
      "roundness": null,
      "seed": 1357005402,
      "version": 471,
      "versionNonce": 153754822,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774283373723,
      "link": null,
      "locked": false,
      "text": "The single most important meta-skill: keep talking. Silence feels like uncertainty.\nNarrate your thinking even when you're unsure — \"I'm considering X because of Y, but\nthe downside is Z...\" is exactly what interviewers want to hear.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The single most important meta-skill: keep talking. Silence feels like uncertainty. Narrate your thinking even when you're unsure — \"I'm considering X because of Y, but the downside is Z...\" is exactly what interviewers want to hear.",
      "autoResize": false,
      "lineHeight": 1.25
    },
