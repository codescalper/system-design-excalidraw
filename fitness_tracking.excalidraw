    {
      "id": "0ckTb7plHkxS4ox1WidKC",
      "type": "text",
      "x": -1687.2559497017207,
      "y": 4935.745644695413,
      "width": 373.65972900390625,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4y",
      "roundness": null,
      "seed": 360025424,
      "version": 308,
      "versionNonce": 122066352,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774350619183,
      "link": null,
      "locked": false,
      "text": "SELECT \n    u.name,\n    SUM(a.distance) as total_distance\nFROM activites a \nJOIN users u ON a.userId = u.userId\nWHERE a.state= \"COMPLETE\"\nAND a.type = \"\"RUN\"\nGROUP BY u.userId\nORDER BY total_distance DESC",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SELECT \n    u.name,\n    SUM(a.distance) as total_distance\nFROM activites a \nJOIN users u ON a.userId = u.userId\nWHERE a.state= \"COMPLETE\"\nAND a.type = \"\"RUN\"\nGROUP BY u.userId\nORDER BY total_distance DESC",
      "autoResize": true,
      "lineHeight": 1.25
    },
