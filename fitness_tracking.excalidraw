      "seed": 549555910,
      "version": 1727,
      "versionNonce": 1778331014,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774286957533,
      "link": null,
      "locked": false,
      "text": "1) Use on-device location services to record user GPS coorsinates\n2) Record this evenet data locally in memory buffer \n3) To prevent Loss in device shutdown or batter depletion , periodically persisit\nthis to device's local storage ~10 seconds\n    - for eg: android : room database for largr or sharedPrefernces for smaller\namounts\n4) Send accumulated data to our server in single request or in chunks or implement\nbackgrouns sync mecahnism\n5) Upon confiramtion from remote database, clear on device local storage\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) Use on-device location services to record user GPS coorsinates\n2) Record this evenet data locally in memory buffer \n3) To prevent Loss in device shutdown or batter depletion , periodically persisit this to device's local storage ~10 seconds\n    - for eg: android : room database for largr or sharedPrefernces for smaller amounts\n4) Send accumulated data to our server in single request or in chunks or implement backgrouns sync mecahnism\n5) Upon confiramtion from remote database, clear on device local storage\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
