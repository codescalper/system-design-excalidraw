    {
      "id": "H1FUNqCVJJG3UsFHIeJQ_",
      "type": "text",
      "x": -3090.456049358149,
      "y": -23.307258681687927,
      "width": 270.38958740234375,
      "height": 32.12676273302351,
      "angle": 0,
      "strokeColor": "#1e1e1e",
