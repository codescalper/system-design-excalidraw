      "text": "Step 4 — High-level design",
      "fontSize": 25.70141018641881,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 4 — High-level design",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "8F7xNXDhFSPsfNPz_CBoI",
      "type": "text",
      "x": -2982.8835538783105,
      "y": -656.5788727982426,
      "width": 702.5911882189494,
      "height": 326.38910186418826,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1e",
      "roundness": null,
      "seed": 690565338,
      "version": 1153,
      "versionNonce": 478836294,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774283373723,
      "link": null,
      "locked": false,
      "text": "Now draw the diagram. Walk the interviewer\nthrough a full request: \"User hits the API\n→ load balancer → app server → check\nRedis → if miss, hit DB → return redirect.\"\nName your tech choices and explain why —\n\"Redis because lookups are read-heavy and\nlow-latency is critical.\" This is where most\nof the interview time goes.",
      "fontSize": 32.638910186418826,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Now draw the diagram. Walk the interviewer through a full request: \"User hits the API → load balancer → app server → check Redis → if miss, hit DB → return redirect.\" Name your tech choices and explain why — \"Redis because lookups are read-heavy and low-latency is critical.\" This is where most of the interview time goes.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
