    {
      "id": "I8xEYSyetRUg9iuV85ZR2",
      "type": "text",
      "x": 5438.768300374003,
      "y": -2292.331120933225,
      "width": 836.5728721712323,
      "height": 229.54886891385962,
      "angle": 0,
      "strokeColor": "#121212",
      "backgroundColor": "#fcc2d7",
      "fillStyle": "solid",
