      "isDeleted": false,
      "boundElements": [],
      "updated": 1773766283225,
      "link": null,
      "locked": false,
      "text": "System Design TIPS ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "System Design TIPS ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kaYGV-6y9iXCYP20ylWQf",
      "type": "text",
      "x": 448.63251344964465,
      "y": -5534.236063863225,
      "width": 702.5911882189494,
      "height": 407.9863773302353,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8d",
      "roundness": null,
      "seed": 457827208,
      "version": 657,
      "versionNonce": 1122365944,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773766283225,
      "link": null,
      "locked": false,
      "text": "Never start designing immediately. Spend\nthe first few minutes asking questions. The\ninterviewer often intentionally leaves things\nvague. You want to nail down: what the\nsystem does, who uses it, what scale you're\ndesigning for, and what's explicitly out of\nscope. For a URL shortener: \"Do we need\nanalytics? Custom aliases? Expiry? Mobile vs\nweb?\" This shows you think before you\nbuild.",
      "fontSize": 32.638910186418826,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Never start designing immediately. Spend the first few minutes asking questions. The interviewer often intentionally leaves things vague. You want to nail down: what the system does, who uses it, what scale you're designing for, and what's explicitly out of scope. For a URL shortener: \"Do we need analytics? Custom aliases? Expiry? Mobile vs web?\" This shows you think before you build.",
      "autoResize": false,
      "lineHeight": 1.25
    },
