    {
      "id": "HvxEQ1UsLQk2SW5CQ_TKx",
      "type": "text",
      "x": 2758.434129511398,
      "y": 5674.351360448529,
      "width": 485.85071633733946,
      "height": 251.6014099742534,
      "angle": 0,
      "strokeColor": "#121212",
      "backgroundColor": "white",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bIr",
      "roundness": null,
      "seed": 1552259192,
      "version": 1252,
      "versionNonce": 1090515567,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774596317247,
      "link": null,
      "locked": false,
      "text": "- Cline\\t chunk file(5-10 MB) & fingerprints chunks\n+ full file (`fileId`)\n- Client GETs 'FileMetdata' by 'fileId' (resume if\nexisits)\n\n- if not exists client POSTs '/files/presigned-url';\nbackend saves metdata ('uploading')\n- Client uploads chunks to S3 via presigned URLs\n- S3 notifies backend; backend marks chunks\n'uploadded'\n- When all chunks uploaded, backends marks file\n'uploaded'",
      "fontSize": 16.773427331616894,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Cline\\t chunk file(5-10 MB) & fingerprints chunks + full file (`fileId`)\n- Client GETs 'FileMetdata' by 'fileId' (resume if exisits)\n\n- if not exists client POSTs '/files/presigned-url'; backend saves metdata ('uploading')\n- Client uploads chunks to S3 via presigned URLs\n- S3 notifies backend; backend marks chunks 'uploadded'\n- When all chunks uploaded, backends marks file 'uploaded'",
      "autoResize": false,
      "lineHeight": 1.25
    },
