    {
      "id": "3O_f-qkMUaVutGaic4vfB",
      "type": "text",
      "x": 435.0156098469088,
      "y": -4192.163332357518,
      "width": 366.86737060546875,
      "height": 32.12676273302351,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
